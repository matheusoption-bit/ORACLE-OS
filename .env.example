# ─── LLM Providers ───────────────────────────────────────────────────────────
# Anthropic (pago, melhor qualidade)
ANTHROPIC_API_KEY=sk-ant-api03-...

# Groq (gratuito, 14.400 req/dia — recomendado para dev)
GROQ_API_KEY=gsk_...

# Google Gemini (gratuito, 1.500 req/dia)
GEMINI_API_KEY=AIza...

# OpenRouter (opcional, 50 req/dia grátis)
OPENROUTER_API_KEY=sk-or-...

# ─── Tools ───────────────────────────────────────────────────────────────────
# E2B - Sandboxes de execução de código
E2B_API_KEY=e2b_...

# GitHub MCP Tools
GITHUB_TOKEN=ghp_...

# ─── RAG ─────────────────────────────────────────────────────────────────────
VECTOR_STORE_PATH=./rag/vector-store
EMBEDDING_MODEL=text-embedding-3-large

# ─── App ─────────────────────────────────────────────────────────────────────
LOG_LEVEL=info
PORT=3000
